#!/bin/bash
# check-health — deepseek-reasonix SDK
# Runs as root (default for hooks).
# Verifies the dsnix binary is accessible by the workshop user and reports
# health status via workshopctl.

set -euo pipefail

echo "=== deepseek-reasonix: check-health hook ==="

output=$(sudo -u workshop --login dsnix --help 2>&1) || {
    echo "ERROR: dsnix binary check failed."
    workshopctl set-health error "$output"
    exit 1
}

workshopctl set-health okay
echo "=== check-health: OK ==="
