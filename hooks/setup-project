#!/bin/bash
# setup-project — deepseek-reasonix SDK
# Forces execution as the workshop user to avoid root-permission pollution.
# Installs the AI agent globally via npm and ensures the
# persistent cache storage folder exists.

set -euo pipefail

echo "=== deepseek-reasonix: setup-project hook ==="

# 1. Install the AI agent globally under the workshop user's environment
# Using 'su -l' ensures the user's login environment and PATH are correctly loaded
echo "[1/2] Installing reasonix via npm"
sudo npm install -g reasonix@0.53.2

# 2. Create the persistent cache storage folder and ensure correct ownership
echo "[2/2] Creating cache directory..."
sudo mkdir -p /home/workshop/.cache/reasonix

echo "=== setup-base complete ==="

