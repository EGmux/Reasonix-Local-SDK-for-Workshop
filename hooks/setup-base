#!/bin/bash
# setup-base — deepseek-reasonix SDK
# Runs as root (default for hooks).
# Configures and fetches Node.js 22 LTS via NodeSource, installs required
# system packages, and exports a system-wide DEEPSEEK_CACHE_DIR variable.

set -euo pipefail

echo "=== deepseek-reasonix: setup-base hook ==="

# 1. Install Node.js 22 LTS from NodeSource
echo "[1/3] Adding NodeSource repository for Node.js 22.x..."
curl -fsSL https://deb.nodesource.com/setup_22.x | bash -

# 2. Install required packages (non-interactive)
echo "[2/3] Installing nodejs, build-essential, git..."
DEBIAN_FRONTEND=noninteractive apt-get install -y nodejs build-essential git

# 3. Set system-wide environment variable
echo "[3/3] Exporting DEEPSEEK_CACHE_DIR via /etc/profile.d..."
cat > /etc/profile.d/deepseek-reasonix.sh << 'EOF'
export DEEPSEEK_CACHE_DIR="/home/workshop/.cache/reasonix"
EOF
chmod 644 /etc/profile.d/deepseek-reasonix.sh

echo "=== setup-base complete ==="
